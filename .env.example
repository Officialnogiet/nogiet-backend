# ============================================================
# NOGIET Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/nogiet

# --- JWT Authentication ---
JWT_SECRET=your-jwt-secret-min-10-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-10-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Redis Cache ---
REDIS_URL=redis://localhost:6379

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:5173

# ============================================================
# EMISSION DATA SOURCES
# ============================================================

# --- Carbon Mapper ---
# The primary satellite methane detection source.
# Sign up at: https://data.carbonmapper.org/
# API docs:   https://api.carbonmapper.org/api/v1/docs
CARBON_MAPPER_API_URL=https://api.carbonmapper.org/api/v1
CARBON_MAPPER_EMAIL=
CARBON_MAPPER_PASSWORD=

# --- UNEP IMEO (International Methane Emissions Observatory) — API v2 ---
# v2 base path /api/v2/ (maintained). Auth: Authorization: Bearer <token>
# Docs: https://methanedata.unep.org/api/docs
# Use methanedata.unep.org — api.methanedata.unep.org often does not resolve (DNS).
IMEO_API_URL=https://methanedata.unep.org/api/v2
# Token from API docs Authorize (JWT or API key string)
IMEO_API_KEY=
# bearer (default) | x-api-key | both | auto
IMEO_AUTH_MODE=bearer
# Optional outbound proxy for IMEO traffic if Cloudflare blocks your IP (HTTP/HTTPS proxy URL)
# IMEO_PROXY_URL=http://user:pass@proxyhost:8080
# Optional Cloudflare clearance cookie (paste from a browser that solved the CF challenge)
# IMEO_COOKIE=cf_clearance=...
# ISO3 country filter for IMEO plumes (NGA = Nigeria only). `*` or `ALL` = global.
IMEO_COUNTRY_FILTER=NGA
# Sector filter for IMEO plumes (case-insensitive substring match, comma-separated).
# Default: keeps Oil and Gas only. `*` or `ALL` = every sector.
IMEO_SECTOR_FILTER=oil and gas
# Set true to log full IMEO JSON envelope + first raw record (server stdout)
IMEO_LOG_RESPONSE=false

# --- Sentinel-5P TROPOMI ---
# ESA Copernicus satellite methane column data.
# Register at: https://dataspace.copernicus.eu/
# API docs:    https://documentation.dataspace.copernicus.eu/
TROPOMI_API_URL=https://catalogue.dataspace.copernicus.eu/odata/v1
TROPOMI_API_KEY=

# ============================================================
# NOTIFICATIONS (optional)
# ============================================================

# --- Resend (Email) ---
RESEND_API_KEY=
EMAIL_FROM=NOGIET Portal <noreply@nogiet.gov.ng>

# --- Termii (SMS) ---
TERMII_API_KEY=
TERMII_SENDER_ID=NOGIET
TERMII_BASE_URL=https://v3.api.termii.com

# ============================================================
# FILE STORAGE (optional - Cloudflare R2)
# ============================================================

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nogiet
R2_PUBLIC_URL=
