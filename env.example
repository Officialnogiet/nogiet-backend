NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nogiet

# JWT
JWT_SECRET=your-jwt-secret-at-least-10-chars
JWT_REFRESH_SECRET=your-refresh-secret-at-least-10-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CarbonMapper (required for satellite emission data)
# Sign up at https://data.carbonmapper.org to get credentials
CARBON_MAPPER_API_URL=https://api.carbonmapper.org/api/v1
CARBON_MAPPER_EMAIL=your-carbonmapper-email@example.com
CARBON_MAPPER_PASSWORD=your-carbonmapper-password

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=NOGIET Portal <noreply@nogiet.gov.ng>

# Termii (SMS)
TERMII_API_KEY=
TERMII_SENDER_ID=NOGIET
TERMII_BASE_URL=https://v3.api.termii.com

# Cloudflare R2 (S3-compatible storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nogiet
R2_PUBLIC_URL=

# Redis (for caching CarbonMapper responses)
REDIS_URL=redis://localhost:6379

# Frontend
FRONTEND_URL=http://localhost:5173
